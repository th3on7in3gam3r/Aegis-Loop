# Aegis Loop / code — environment variable template
# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# ── Server (required) ──
PORT=3847
APP_URL=http://localhost:3847
SESSION_SECRET=change-me-to-a-random-string

# ── Data storage (optional — set on Render to match persistent disk mount) ──
# Default: code/data relative to the app. On Render with a disk, use:
# AEGIS_DATA_DIR=/opt/render/project/src/code/data
AEGIS_DATA_DIR=

# ── Public site (set when you add a custom domain) ──
# APP_URL=https://yourdomain.com
# GitHub OAuth callback: https://yourdomain.com/api/auth/github/callback
# Render custom domain: Dashboard → service → Settings → Custom Domains → add CNAME to your DNS
CONTACT_EMAIL=hello@aegisloop.dev

# ── GitHub OAuth (recommended for dashboard login) ──
# Create at: https://github.com/settings/developers
# Homepage URL:        http://localhost:3847
# Callback URL:        http://localhost:3847/api/auth/github/callback
# Enables "Continue with GitHub" — users log in via browser, no PAT needed.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GITHUB_TOKEN (optional — server-side only) ──
# A Personal Access Token with `repo` scope, used when NO user is logged in:
#   • Webhook auto-scans (background, no browser session)
#   • Autofix fallback if server handles requests without OAuth session
# NOT needed if you only use the dashboard with OAuth/PAT login.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── GITHUB_WEBHOOK_SECRET (optional — auto-scan on every PR) ──
# Only needed when GitHub sends webhooks to your server automatically.
# Requires a PUBLIC URL (ngrok, deployed server) — localhost won't receive webhooks.
# Set the same secret in your repo webhook settings:
#   URL:    https://YOUR_PUBLIC_URL/api/webhooks/github
#   Events: Pull requests
# Also requires GITHUB_TOKEN above so the server can clone and comment.
GITHUB_WEBHOOK_SECRET=

# ── LLM autofix (optional — AI-generated fixes for findings without templates) ──
# Pick one provider and set its API key. OSV dependency scanning works without these.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Stripe billing (Team plan — optional) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TEAM_PRICE_ID=

# ── Studio Ops fan-out (optional — identity is GitHub login) ──
# Outbound webhook for user.signup, subscription.*, and bundle.* events.
STUDIO_OPS_WEBHOOK_URL=
STUDIO_OPS_WEBHOOK_SECRET=
